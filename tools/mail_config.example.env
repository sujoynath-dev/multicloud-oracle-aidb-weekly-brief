# Optional SMTP fallback for tools/send_weekly_brief_email.py.
# The default automation uses Microsoft Outlook for macOS and does not need these values.
#
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_STARTTLS=true
# MAIL_SMTP_SSL=false
# MAIL_SMTP_USERNAME=sujoy.nath@oracle.com
# MAIL_SMTP_PASSWORD=replace-with-app-password-or-secret
# MAIL_FROM=sujoy.nath@oracle.com
